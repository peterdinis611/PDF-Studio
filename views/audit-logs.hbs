<div
  class="audit-page relative flex h-full flex-col bg-slate-panel"
  x-data="auditLogsPage({ locked: {{#if locked}}true{{else}}false{{/if}}, tokenRequired: {{#if tokenRequired}}true{{else}}false{{/if}} })"
  @keydown.window="onKey($event)"
>
  <div class="audit-glow pointer-events-none absolute inset-0" aria-hidden="true"></div>

  <header class="relative z-20 flex shrink-0 items-center justify-between gap-4 border-b border-slate-line/60 px-4 py-3 md:px-6">
    <div class="flex items-center gap-3">
      <a href="/" class="flex items-center gap-2.5">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent text-xs font-bold text-white shadow-sm">PS</span>
        <span class="hidden text-sm font-semibold tracking-tight text-fg sm:inline">PDF Studio</span>
      </a>
      <span class="hidden h-4 w-px bg-slate-line sm:block"></span>
      <div class="min-w-0">
        <h1 class="text-sm font-semibold tracking-tight text-fg md:text-base">Audit logs</h1>
        <p class="truncate font-mono text-[10px] text-slate-muted">pino · memory · <span x-text="capacity"></span> cap</p>
      </div>
    </div>
    <div class="flex items-center gap-1.5">
      <span class="audit-live" x-show="autoRefresh && !locked" x-cloak>
        <span class="audit-live-dot"></span>
        live
      </span>
      <button type="button" class="tool-btn h-9 w-9" @click="toggleTheme()" :title="theme === 'dark' ? 'Light mode' : 'Dark mode'">
        <svg x-show="theme === 'dark'" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.4 6.4l-1.4-1.4M7 7L5.6 5.6m12.8 0L17 7M7 17l-1.4 1.4M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg x-show="theme === 'light'" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z" />
        </svg>
      </button>
      <a href="/editor" class="btn-primary hidden sm:inline-flex">Editor</a>
    </div>
  </header>

  {{!-- Unlock --}}
  <div class="relative z-10 flex flex-1 items-center justify-center overflow-y-auto p-6" x-show="locked" x-cloak>
    <form class="audit-unlock w-full max-w-sm" @submit.prevent="unlock()">
      <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-accent-soft">Restricted</p>
      <h2 class="mt-2 text-xl font-semibold text-fg">Enter audit token</h2>
      <p class="mt-2 text-sm text-slate-muted">Required by <span class="font-mono text-fg/80">AUDIT_LOGS_TOKEN</span>.</p>
      <input type="password" autocomplete="off" class="audit-input mt-5 w-full" x-model="token" placeholder="Token" />
      <p class="mt-2 text-sm text-rose-500" x-show="error" x-text="error"></p>
      <button type="submit" class="btn-primary mt-4 w-full justify-center">Unlock</button>
    </form>
  </div>

  {{!-- Main console --}}
  <div class="relative z-10 flex min-h-0 flex-1 flex-col" x-show="!locked" x-cloak>
    <div class="shrink-0 space-y-3 border-b border-slate-line/60 px-4 py-3 md:px-6">
      <div class="flex flex-wrap items-center gap-1.5">
        <button type="button" class="audit-pill" :class="level === '' && 'is-on'" @click="setLevel('')">
          All <em x-text="counts.all"></em>
        </button>
        <button type="button" class="audit-pill audit-pill--info" :class="level === 'info' && 'is-on'" @click="setLevel('info')">
          Info <em x-text="counts.info"></em>
        </button>
        <button type="button" class="audit-pill audit-pill--warn" :class="level === 'warn' && 'is-on'" @click="setLevel('warn')">
          Warn <em x-text="counts.warn"></em>
        </button>
        <button type="button" class="audit-pill audit-pill--error" :class="level === 'error' && 'is-on'" @click="setLevel('error')">
          Error <em x-text="counts.error"></em>
        </button>
        <div class="ml-auto flex items-center gap-2">
          <label class="audit-check">
            <input type="checkbox" x-model="autoRefresh" />
            Auto
          </label>
          <button type="button" class="tool-btn h-8 w-8" @click="load()" title="Refresh now">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M5 19a9 9 0 0014.1-6.1M19 5A9 9 0 004.9 11" />
            </svg>
          </button>
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <div class="relative min-w-[12rem] flex-1">
          <svg class="pointer-events-none absolute left-2.5 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-slate-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.3-4.3m1.3-5.2a6.5 6.5 0 11-13 0 6.5 6.5 0 0113 0z" />
          </svg>
          <input type="search" class="audit-input w-full py-1.5 pl-8 text-xs" placeholder="Filter message, action, IP, session…" x-model="q" @input="load()" />
        </div>
        <select class="audit-input py-1.5 text-xs" x-model="action" @change="load()">
          <option value="">All actions</option>
          <option value="pdf.export">pdf.export</option>
          <option value="image.upload">image.upload</option>
          <option value="server.start">server.start</option>
          <option value="audit.view">audit.view</option>
          <option value="http.error">http.error</option>
        </select>
      </div>
      <p class="text-xs text-rose-500" x-show="error" x-text="error"></p>
    </div>

    <div class="flex min-h-0 flex-1">
      {{!-- Stream --}}
      <section class="flex min-h-0 min-w-0 flex-1 flex-col">
        <div class="flex shrink-0 items-center justify-between px-4 py-2 md:px-5">
          <p class="font-mono text-[10px] uppercase tracking-wider text-slate-muted">
            <span class="text-fg/70" x-text="total"></span> events
            <span class="text-slate-muted/60"> · ↑↓ navigate · enter open</span>
          </p>
          <p class="text-[11px] text-accent-soft" x-show="copied" x-text="copied"></p>
        </div>

        <div class="min-h-0 flex-1 overflow-y-auto px-2 pb-4 md:px-3" id="audit-stream">
          <div class="audit-empty" x-show="!loading && events.length === 0" x-cloak>
            <p class="text-sm font-medium text-fg">Quiet so far</p>
            <p class="mt-1 text-xs text-slate-muted">Export a PDF or upload an image to generate audit events.</p>
          </div>

          <ul class="space-y-0.5">
            <template x-for="(event, index) in events" :key="event.id">
              <li>
                <button
                  type="button"
                  class="audit-row"
                  :class="selectedId === event.id && 'is-selected'"
                  :data-index="index"
                  @click="select(event.id)"
                >
                  <span class="audit-row-rail" :data-level="event.level"></span>
                  <span class="min-w-0 flex-1">
                    <span class="flex items-center gap-2">
                      <span class="audit-badge" :data-level="event.level" x-text="event.level"></span>
                      <span class="truncate font-mono text-[11px] text-accent-soft" x-text="event.action"></span>
                      <span class="ml-auto shrink-0 font-mono text-[10px] text-slate-muted" x-text="relativeTs(event.ts)" :title="formatTs(event.ts)"></span>
                    </span>
                    <span class="mt-0.5 block truncate text-[13px] leading-snug text-fg" x-text="event.message"></span>
                    <span class="mt-0.5 flex gap-2 truncate font-mono text-[10px] text-slate-muted">
                      <span x-show="event.req?.method" x-text="reqLine(event)"></span>
                      <span x-show="event.sessionId" x-text="shortSession(event.sessionId)"></span>
                    </span>
                  </span>
                </button>
              </li>
            </template>
          </ul>
        </div>
      </section>

      {{!-- Desktop inspector --}}
      <aside class="audit-detail hidden w-[min(100%,22rem)] shrink-0 flex-col border-l border-slate-line/60 xl:w-[26rem] lg:flex">
        <div class="flex flex-1 flex-col items-center justify-center px-6 text-center" x-show="!selectedId" x-cloak>
          <div class="audit-empty-icon">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M12 3a9 9 0 100 18 9 9 0 000-18z" />
            </svg>
          </div>
          <p class="mt-3 text-sm font-medium text-fg">Pick an event</p>
          <p class="mt-1 max-w-[14rem] text-xs text-slate-muted">Request context and meta show up here.</p>
        </div>

        <div class="flex min-h-0 flex-1 flex-col" x-show="selectedId && selected" x-cloak>
          <div class="shrink-0 border-b border-slate-line/60 px-4 py-3.5">
            <div class="flex items-start gap-2">
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-1.5">
                  <span class="audit-badge" :data-level="selected?.level" x-text="selected?.level"></span>
                  <span class="font-mono text-[11px] text-accent-soft" x-text="selected?.action"></span>
                </div>
                <p class="mt-1.5 text-sm font-medium leading-snug text-fg" x-text="selected?.message"></p>
                <p class="mt-1 font-mono text-[10px] text-slate-muted" x-text="selected ? formatTs(selected.ts) : ''"></p>
              </div>
              <button type="button" class="tool-btn h-8 shrink-0 px-2 text-[11px]" @click="selected && copyEvent(selected)">Copy</button>
            </div>
          </div>

          <div class="min-h-0 flex-1 space-y-5 overflow-y-auto px-4 py-4">
            <div>
              <p class="audit-section-label">Request</p>
              <div class="audit-kv mt-2">
                <div><span>Method</span><strong x-text="selected?.req?.method || '—'"></strong></div>
                <div><span>Status</span><strong x-text="selected?.req?.status ?? '—'"></strong></div>
                <div class="audit-kv-wide"><span>Path</span><strong class="break-all" x-text="selected?.req?.path || '—'"></strong></div>
                <div><span>IP</span><strong x-text="selected?.req?.ip || '—'"></strong></div>
                <div><span>Req</span><strong x-text="selected?.req?.requestId || '—'"></strong></div>
                <div class="audit-kv-wide"><span>Session</span><strong class="break-all" x-text="selected?.sessionId || '—'"></strong></div>
              </div>
            </div>

            <div x-show="selected && metaEntries(selected).length" x-cloak>
              <p class="audit-section-label">Meta</p>
              <div class="mt-2 flex flex-wrap gap-1.5">
                <template x-for="pair in (selected ? metaEntries(selected) : [])" :key="pair[0]">
                  <span class="audit-chip"><span x-text="pair[0]"></span><strong x-text="pair[1]"></strong></span>
                </template>
              </div>
            </div>

            <div x-show="selected?.req?.userAgent" x-cloak>
              <p class="audit-section-label">User-Agent</p>
              <p class="mt-1.5 break-all font-mono text-[10px] leading-relaxed text-slate-muted" x-text="selected?.req?.userAgent"></p>
            </div>

            <div>
              <button type="button" class="audit-section-label flex w-full items-center justify-between py-0.5" @click="showRaw = !showRaw">
                <span>Raw JSON</span>
                <svg class="h-3.5 w-3.5 transition" :class="showRaw && 'rotate-180'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <pre class="audit-json mt-2" x-show="showRaw && selected" x-cloak x-text="selected ? prettyJson(selected) : ''"></pre>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <footer class="status-bar relative z-10">
      <div class="flex items-center gap-2 overflow-hidden">
        <span class="status-chip" x-text="`${total} shown`"></span>
        <span class="status-chip" x-text="`cap ${capacity}`"></span>
        <span class="truncate text-[11px] text-slate-muted" x-text="selected ? selected.action : 'No selection'"></span>
      </div>
      <span class="font-mono text-[10px] text-slate-muted">localhost audit</span>
    </footer>
  </div>

  {{!-- Mobile sheet --}}
  <div class="fixed inset-0 z-40 lg:hidden" x-show="!locked && selectedId" x-cloak x-transition.opacity>
    <div class="absolute inset-0 bg-black/55" @click="selectedId = ''"></div>
    <div class="audit-sheet absolute inset-x-0 bottom-0 max-h-[82vh] overflow-y-auto p-4" x-show="selected">
      <div class="mx-auto mb-3 h-1 w-9 rounded-full bg-slate-line"></div>
      <div class="flex items-start justify-between gap-2">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-1.5">
            <span class="audit-badge" :data-level="selected?.level" x-text="selected?.level"></span>
            <span class="font-mono text-[11px] text-accent-soft" x-text="selected?.action"></span>
          </div>
          <p class="mt-1.5 text-sm font-medium text-fg" x-text="selected?.message"></p>
        </div>
        <button type="button" class="tool-btn h-8 w-8" @click="selectedId = ''">×</button>
      </div>
      <div class="audit-kv mt-3">
        <div><span>Method</span><strong x-text="selected?.req?.method || '—'"></strong></div>
        <div><span>Status</span><strong x-text="selected?.req?.status ?? '—'"></strong></div>
        <div class="audit-kv-wide"><span>Path</span><strong class="break-all" x-text="selected?.req?.path || '—'"></strong></div>
        <div class="audit-kv-wide"><span>Session</span><strong class="break-all" x-text="selected?.sessionId || '—'"></strong></div>
      </div>
      <div class="mt-3 flex gap-2">
        <button type="button" class="btn-primary flex-1 justify-center" @click="selected && copyEvent(selected)">Copy JSON</button>
        <button type="button" class="tool-btn flex-1 px-3 text-xs" @click="showRaw = !showRaw" x-text="showRaw ? 'Hide JSON' : 'JSON'"></button>
      </div>
      <pre class="audit-json mt-3" x-show="showRaw && selected" x-cloak x-text="selected ? prettyJson(selected) : ''"></pre>
    </div>
  </div>
</div>
