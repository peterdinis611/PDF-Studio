<div class="relative h-full overflow-y-auto bg-slate-panel" x-data="themeToggle">
  <div class="home-atmosphere pointer-events-none absolute inset-0"></div>

  <header class="relative z-10 flex items-center justify-between px-6 py-5 md:px-10">
    <a href="/" class="flex items-center gap-2.5">
      <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent text-sm font-bold text-white">PS</span>
      <span class="text-lg font-semibold tracking-tight text-fg">PDF Studio</span>
    </a>
    <div class="flex items-center gap-2">
      <button
        type="button"
        class="tool-btn h-9 w-9"
        @click="toggleTheme()"
        :title="theme === 'dark' ? 'Light mode' : 'Dark mode'"
      >
        <svg x-show="theme === 'dark'" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.4 6.4l-1.4-1.4M7 7L5.6 5.6m12.8 0L17 7M7 17l-1.4 1.4M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
        <svg x-show="theme === 'light'" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z" />
        </svg>
      </button>
      <a
        href="/audit-logs"
        class="hidden rounded-xl border border-slate-line px-3 py-2 text-sm text-slate-muted transition hover:border-slate-muted hover:text-fg sm:inline-flex"
      >Audit logs</a>
      <a href="/editor" class="btn-primary">Open editor</a>
    </div>
  </header>

  <main class="relative z-10 mx-auto flex max-w-5xl flex-col px-6 pb-24 pt-10 md:px-10 md:pt-16">
    <div class="home-hero">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-accent-soft">Online PDF builder</p>
      <h1 class="mt-4 max-w-2xl text-5xl font-semibold leading-[1.05] tracking-tight text-fg md:text-7xl">
        PDF Studio
      </h1>
      <p class="mt-5 max-w-lg text-lg leading-relaxed text-slate-muted">
        Design multi-page documents in the browser, then export a real PDF — no account needed.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a
          href="/editor?new=1"
          class="inline-flex items-center gap-2 rounded-xl bg-fg px-5 py-3 text-sm font-semibold transition hover:opacity-90"
          style="color: rgb(var(--color-panel))"
        >
          Start blank
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/editor?template=invoice"
          class="inline-flex items-center rounded-xl border border-slate-line px-5 py-3 text-sm font-medium text-slate-muted transition hover:border-slate-muted hover:text-fg"
        >
          Try invoice
        </a>
      </div>
    </div>

    <section class="mt-24">
      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-muted">Templates</h2>
          <p class="mt-1 text-sm text-slate-muted">Pick a starting layout and customize every element.</p>
        </div>
      </div>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/editor?new=1" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #faf9f6, #e7e2d8)"></span>
          <span>
            <span class="block font-medium text-fg">Blank A4</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Empty canvas</span>
          </span>
        </a>
        <a href="/editor?template=invoice" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #0f766e, #99f6e4)"></span>
          <span>
            <span class="block font-medium text-fg">Invoice</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Header, line items, totals</span>
          </span>
        </a>
        <a href="/editor?template=letter" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #f8fafc, #cbd5e1)"></span>
          <span>
            <span class="block font-medium text-fg">Letter</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Formal correspondence</span>
          </span>
        </a>
        <a href="/editor?template=flyer" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #0d9488, #f59e0b)"></span>
          <span>
            <span class="block font-medium text-fg">Flyer</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Bold promo layout</span>
          </span>
        </a>
        <a href="/editor?template=cv" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(90deg, #0f766e 38%, #f1f5f9 38%)"></span>
          <span>
            <span class="block font-medium text-fg">CV / Resume</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Sidebar with experience</span>
          </span>
        </a>
        <a href="/editor?template=report" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #134e4a, #5eead4)"></span>
          <span>
            <span class="block font-medium text-fg">Report</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Summary, metrics, next steps</span>
          </span>
        </a>
        <a href="/editor?template=certificate" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #fffbeb, #0d9488)"></span>
          <span>
            <span class="block font-medium text-fg">Certificate</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Award with dual border</span>
          </span>
        </a>
        <a href="/editor?template=menu" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #1c1917, #0d9488)"></span>
          <span>
            <span class="block font-medium text-fg">Menu</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Starters, mains, desserts</span>
          </span>
        </a>
        <a href="/editor?template=proposal" class="home-template">
          <span class="home-template-swatch" style="background: linear-gradient(135deg, #0f172a, #14b8a6)"></span>
          <span>
            <span class="block font-medium text-fg">Proposal</span>
            <span class="mt-0.5 block text-sm text-slate-muted">Scope, timeline, investment</span>
          </span>
        </a>
      </div>
    </section>
  </main>
</div>
