<aside class="flex w-36 shrink-0 flex-col border-r border-slate-line bg-slate-panel md:w-44">
  <div class="flex items-center justify-between border-b border-slate-line px-3 py-2.5">
    <span class="text-xs font-medium uppercase tracking-wider text-slate-muted">Pages</span>
    <button type="button" class="tool-btn h-8 w-8" @click="addPage()" title="Add page">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
    </button>
  </div>

  <div class="flex-1 space-y-3 overflow-y-auto p-2.5">
    <template x-for="(page, index) in doc.pages" :key="page.id">
      <div class="group relative">
        <button
          type="button"
          class="page-thumb"
          :aria-current="index === activePageIndex ? 'true' : 'false'"
          :style="pageThumbStyle"
          @click="setActivePage(index)"
        >
          <span
            class="pointer-events-none absolute inset-0 origin-top-left scale-[0.35] overflow-hidden"
            :style="`width: ${pageSize.width}px; height: ${pageSize.height}px;`"
          >
            <template x-for="el in page.elements" :key="el.id">
              <div class="absolute" :style="thumbElementStyle(el)" x-html="thumbPreview(el)"></div>
            </template>
          </span>
          <span
            class="absolute bottom-1.5 left-1.5 rounded-md bg-ink/75 px-1.5 py-0.5 font-mono text-[10px] text-white backdrop-blur-sm"
            x-text="index + 1"
          ></span>
        </button>

        <div class="mt-1 flex justify-center gap-0.5 opacity-0 transition group-hover:opacity-100 group-focus-within:opacity-100">
          <button type="button" class="tool-btn h-7 w-7" @click="movePage(index, -1)" title="Move up" :disabled="index === 0">↑</button>
          <button type="button" class="tool-btn h-7 w-7" @click="movePage(index, 1)" title="Move down" :disabled="index === doc.pages.length - 1">↓</button>
          <button type="button" class="tool-btn h-7 w-7" @click="duplicatePage(index)" title="Duplicate page">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
              <rect x="8" y="8" width="11" height="11" rx="1" />
              <path stroke-linecap="round" d="M6 16V6a1 1 0 011-1h10" />
            </svg>
          </button>
          <button
            type="button"
            class="tool-btn h-7 w-7 text-warn/80 hover:text-warn"
            x-show="doc.pages.length > 1"
            @click="removePage(index)"
            title="Delete page"
          >×</button>
        </div>
      </div>
    </template>
  </div>
</aside>
