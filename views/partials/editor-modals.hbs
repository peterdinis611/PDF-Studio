{{!-- Shared modals --}}
<div
  x-show="showExportModal"
  x-cloak
  class="modal-backdrop"
  @keydown.escape.window="showExportModal = false"
>
  <div class="modal-panel" @click.outside="showExportModal = false">
    <h3 class="modal-title">Export PDF</h3>
    <p class="mt-1 text-xs text-slate-muted">Choose quality options, then download.</p>
    <div class="mt-5 space-y-4 text-sm">
      <div>
        <label class="panel-label">Margin (pt)</label>
        <input type="number" min="0" max="72" class="panel-input" x-model.number="exportSettings.margin" />
      </div>
      <div>
        <label class="panel-label">Image quality</label>
        <input type="range" min="0.4" max="1" step="0.05" class="w-full accent-accent" x-model.number="exportSettings.imageQuality" />
        <p class="mt-1 text-xs text-slate-muted" x-text="Math.round(exportSettings.imageQuality * 100) + '%'"></p>
      </div>
      <label class="settings-row">
        <span>Flatten form fields</span>
        <input type="checkbox" class="accent-accent" x-model="exportSettings.flatten" />
      </label>
      <label class="settings-row">
        <span>PDF/A-friendly metadata</span>
        <input type="checkbox" class="accent-accent" x-model="exportSettings.pdfaLite" />
      </label>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn-ghost" @click="showExportModal = false">Cancel</button>
      <button type="button" class="btn-primary" :disabled="exporting" @click="exportPdf()">
        <span x-text="exporting ? 'Exporting…' : 'Download PDF'"></span>
      </button>
    </div>
  </div>
</div>

<div x-show="showFindReplace" x-cloak class="modal-backdrop items-start pt-24">
  <div class="modal-panel max-w-lg" @click.outside="showFindReplace = false">
    <h3 class="modal-title">Find &amp; replace</h3>
    <div class="mt-4 grid gap-3 sm:grid-cols-2">
      <div>
        <label class="panel-label">Find</label>
        <input type="text" class="panel-input" x-model="findQuery" @keydown.enter="runFind()" />
      </div>
      <div>
        <label class="panel-label">Replace</label>
        <input type="text" class="panel-input" x-model="replaceQuery" />
      </div>
    </div>
    <p class="mt-3 text-xs text-slate-muted">
      <span x-text="findMatches.length"></span> matches
      <span x-show="findIndex >= 0" x-text="' · #' + (findIndex + 1)"></span>
    </p>
    <div class="modal-actions flex-wrap">
      <button type="button" class="btn-ghost" @click="runFind()">Find</button>
      <button type="button" class="btn-ghost" @click="findNext()">Next</button>
      <button type="button" class="btn-ghost" @click="replaceCurrent()">Replace</button>
      <button type="button" class="btn-ghost" @click="replaceAll()">Replace all</button>
      <button type="button" class="btn-ghost ml-auto" @click="showFindReplace = false">Close</button>
    </div>
  </div>
</div>

<div x-show="showBrandKit" x-cloak class="modal-backdrop">
  <div class="modal-panel" @click.outside="showBrandKit = false">
    <h3 class="modal-title">Brand kit</h3>
    <p class="mt-1 text-xs text-slate-muted">Saved in this browser only.</p>
    <div class="mt-4 space-y-3 text-sm">
      <div>
        <label class="panel-label">Brand name</label>
        <input type="text" class="panel-input" x-model="brand.name" @change="saveBrand()" />
      </div>
      <div>
        <label class="panel-label">Default font</label>
        <select class="panel-select" x-model="brand.defaultFont" @change="saveBrand()">
          <template x-for="f in fontOptions" :key="f.id">
            <option :value="f.id" x-text="f.label"></option>
          </template>
        </select>
      </div>
      <div>
        <label class="panel-label">Colors</label>
        <div class="flex flex-wrap gap-2">
          <template x-for="(c, i) in brand.colors" :key="i">
            <input type="color" class="h-9 w-12 cursor-pointer rounded-lg border border-slate-line bg-transparent" x-model="brand.colors[i]" @change="saveBrand()" />
          </template>
        </div>
      </div>
      <div>
        <label class="panel-label">Logo</label>
        <div class="flex flex-wrap gap-2">
          <button type="button" class="btn-ghost" @click="$refs.brandLogoInput.click()">Upload logo</button>
          <button type="button" class="btn-ghost" :disabled="!brand.logoUrl" @click="insertBrandLogo()">Insert logo</button>
        </div>
        <p class="mt-1 truncate text-xs text-slate-muted" x-text="brand.logoName || 'No logo yet'"></p>
      </div>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn-ghost" @click="applyBrandToSelection()">Apply to selection</button>
      <button type="button" class="btn-primary" @click="saveBrand(); showBrandKit = false">Done</button>
    </div>
  </div>
</div>

<div x-show="showDocLibrary" x-cloak class="modal-backdrop">
  <div class="modal-panel max-w-lg" @click.outside="showDocLibrary = false">
    <h3 class="modal-title">Local documents</h3>
    <p class="mt-1 text-xs text-slate-muted">Stored in your browser. Share via JSON download.</p>
    <div class="mt-4 flex flex-wrap gap-2">
      <button type="button" class="btn-ghost" @click="newDocument()">New</button>
      <button type="button" class="btn-ghost" @click="$refs.jsonInput.click()">Open JSON</button>
      <button type="button" class="btn-ghost" @click="$refs.pdfInput.click()">Open PDF</button>
      <button type="button" class="btn-ghost" @click="downloadStudioJson()">Share JSON</button>
      <button type="button" class="btn-ghost" @click="duplicateDocInLibrary()">Duplicate</button>
    </div>
    <ul class="mt-4 max-h-64 space-y-1.5 overflow-y-auto">
      <template x-for="d in docLibrary" :key="d.id">
        <li>
          <button
            type="button"
            class="doc-row"
            :class="d.id === doc.id && 'is-active'"
            @click="openDocFromLibrary(d.id)"
          >
            <span class="truncate font-medium text-fg" x-text="d.name"></span>
            <span class="ml-2 shrink-0 font-mono text-[10px] text-slate-muted" x-text="new Date(d.updatedAt).toLocaleString()"></span>
          </button>
        </li>
      </template>
      <li x-show="docLibrary.length === 0" class="py-8 text-center text-sm text-slate-muted">No saved documents yet.</li>
    </ul>
    <div class="modal-actions">
      <button type="button" class="btn-ghost ml-auto" @click="showDocLibrary = false">Close</button>
    </div>
  </div>
</div>

{{!-- Signature modal --}}
<div
  x-show="showSignatureModal"
  x-cloak
  class="modal-backdrop"
  @keydown.escape.window="closeSignatureModal()"
>
  <div class="modal-panel max-w-xl" @click.outside="closeSignatureModal()">
    <h3 class="modal-title">Sign document</h3>
    <p class="mt-1 text-xs text-slate-muted">Draw, type, or upload a signature — it will be placed on the page.</p>

    <div class="mt-4 flex gap-1 rounded-xl border border-slate-line bg-black/5 p-1 dark:bg-white/5">
      <button type="button" class="flex-1 rounded-lg px-3 py-1.5 text-xs font-medium" :class="signatureTab === 'draw' ? 'bg-slate-panel text-fg shadow-sm' : 'text-slate-muted'" @click="signatureTab = 'draw'; resetSignaturePad()">Draw</button>
      <button type="button" class="flex-1 rounded-lg px-3 py-1.5 text-xs font-medium" :class="signatureTab === 'type' ? 'bg-slate-panel text-fg shadow-sm' : 'text-slate-muted'" @click="signatureTab = 'type'; clearSignaturePad()">Type</button>
      <button type="button" class="flex-1 rounded-lg px-3 py-1.5 text-xs font-medium" :class="signatureTab === 'upload' ? 'bg-slate-panel text-fg shadow-sm' : 'text-slate-muted'" @click="signatureTab = 'upload'">Upload</button>
    </div>

    <div class="mt-4" x-show="signatureTab !== 'upload'">
      <div class="mb-2 flex items-center justify-between gap-3">
        <label class="flex items-center gap-2 text-xs text-slate-muted">
          Ink
          <input type="color" class="h-7 w-9 cursor-pointer rounded border border-slate-line bg-transparent" x-model="signatureInk" @change="signatureTab === 'type' && renderTypedSignature()" />
        </label>
        <button type="button" class="text-xs text-slate-muted underline hover:text-fg" @click="clearSignaturePad()">Clear</button>
      </div>
      <div x-show="signatureTab === 'type'" class="mb-2">
        <input
          type="text"
          class="panel-input"
          placeholder="Type your name"
          x-model="signatureTyped"
          @input="renderTypedSignature()"
        />
      </div>
      <canvas
        x-ref="signaturePad"
        class="h-44 w-full cursor-crosshair touch-none rounded-xl border border-dashed border-slate-line bg-white"
        style="touch-action: none"
        @pointerdown="onSignaturePointerDown($event)"
        @pointermove="onSignaturePointerMove($event)"
        @pointerup="onSignaturePointerUp($event)"
        @pointerleave="onSignaturePointerUp($event)"
      ></canvas>
      <p class="mt-1.5 text-[10px] text-slate-muted" x-show="signatureTab === 'draw'">Draw with mouse or finger on the pad above.</p>
    </div>

    <div class="mt-4" x-show="signatureTab === 'upload'">
      <button type="button" class="btn-ghost w-full justify-center py-8" @click="$refs.signatureFileInput.click()">
        Choose PNG or JPEG signature image…
      </button>
    </div>

    <div class="modal-actions">
      <button type="button" class="btn-ghost" @click="closeSignatureModal()">Cancel</button>
      <button
        type="button"
        class="btn-primary"
        :disabled="signatureBusy || (signatureTab !== 'upload' && !signatureHasInk && !signatureTyped.trim())"
        @click="confirmSignature()"
      >
        <span x-text="signatureBusy ? 'Adding…' : (signatureTab === 'upload' ? 'Choose file' : 'Add signature')"></span>
      </button>
    </div>
  </div>
</div>
