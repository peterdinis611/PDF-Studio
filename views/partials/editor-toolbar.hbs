<header class="relative flex h-14 shrink-0 items-center gap-2 border-b border-slate-line bg-slate-panel px-2 md:gap-3 md:px-4">
  <a href="/" class="flex items-center gap-2 pr-1" title="Home">
    <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent text-xs font-bold text-white">PS</span>
    <span class="hidden text-sm font-semibold text-fg lg:inline">PDF Studio</span>
  </a>

  <div class="h-6 w-px bg-slate-line"></div>

  <input
    type="text"
    class="panel-input max-w-[8rem] border-transparent bg-transparent font-medium hover:border-slate-line sm:max-w-[12rem]"
    x-model="doc.name"
    @change="persist()"
    aria-label="Document name"
  />

  <div class="flex items-center gap-0.5">
    <button type="button" class="tool-btn h-8 w-8" :disabled="!canUndo" @click="undo()" title="Undo (⌘Z)">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 14l-4-4 4-4m-4 4h11a4 4 0 010 8h-1" />
      </svg>
    </button>
    <button type="button" class="tool-btn h-8 w-8" :disabled="!canRedo" @click="redo()" title="Redo (⌘Y)">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 14l4-4-4-4m4 4H8a4 4 0 000 8h1" />
      </svg>
    </button>
  </div>

  <button type="button" class="btn-ghost hidden sm:inline-flex" @click="showTemplates = !showTemplates">Templates</button>
  <button type="button" class="btn-ghost hidden md:inline-flex" @click="newDocument()">New</button>

  <div class="ml-auto flex items-center gap-1.5 sm:gap-2">
    <button
      type="button"
      class="tool-btn h-8 w-8"
      @click="toggleTheme()"
      :title="theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode'"
    >
      <svg x-show="theme === 'dark'" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.4 6.4l-1.4-1.4M7 7L5.6 5.6m12.8 0L17 7M7 17l-1.4 1.4M12 8a4 4 0 100 8 4 4 0 000-8z" />
      </svg>
      <svg x-show="theme === 'light'" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.8A9 9 0 1111.2 3a7 7 0 009.8 9.8z" />
      </svg>
    </button>

    <button type="button" class="tool-btn h-8 w-8" @click="showSettings = !showSettings" title="More options">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15.5a3.5 3.5 0 100-7 3.5 3.5 0 000 7z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.4 15a1.7 1.7 0 00.3 1.8l.1.1a2 2 0 11-2.8 2.8l-.1-.1a1.7 1.7 0 00-1.8-.3 1.7 1.7 0 00-1 1.5V21a2 2 0 11-4 0v-.1a1.7 1.7 0 00-1-1.5 1.7 1.7 0 00-1.8.3l-.1.1a2 2 0 11-2.8-2.8l.1-.1a1.7 1.7 0 00.3-1.8 1.7 1.7 0 00-1.5-1H3a2 2 0 110-4h.1a1.7 1.7 0 001.5-1 1.7 1.7 0 00-.3-1.8l-.1-.1a2 2 0 112.8-2.8l.1.1a1.7 1.7 0 001.8.3H9a1.7 1.7 0 001-1.5V3a2 2 0 114 0v.1a1.7 1.7 0 001 1.5 1.7 1.7 0 001.8-.3l.1-.1a2 2 0 112.8 2.8l-.1.1a1.7 1.7 0 00-.3 1.8V9c.2.6.7 1 1.5 1H21a2 2 0 110 4h-.1a1.7 1.7 0 00-1.5 1z" />
      </svg>
    </button>

    <select class="panel-select w-auto min-w-[6.5rem]" x-model="doc.pageSize" @change="persist()">
      <option value="a4">A4</option>
      <option value="a5">A5</option>
      <option value="letter">US Letter</option>
      <option value="legal">Legal</option>
      <option value="square">Square</option>
    </select>

    <button type="button" class="rounded-lg border border-slate-line px-2.5 py-1.5 text-sm text-slate-muted hover:text-fg" @click="zoomOut()" title="Zoom out">−</button>
    <button type="button" class="w-12 text-center font-mono text-xs text-slate-muted hover:text-fg" @click="fitZoom()" title="Fit width" x-text="Math.round(zoom * 100) + '%'"></button>
    <button type="button" class="rounded-lg border border-slate-line px-2.5 py-1.5 text-sm text-slate-muted hover:text-fg" @click="zoomIn()" title="Zoom in">+</button>

    <button
      type="button"
      class="ml-1 inline-flex items-center gap-2 rounded-lg bg-accent px-3 py-1.5 text-sm font-medium text-white transition hover:bg-accent-dim disabled:opacity-50"
      :disabled="exporting"
      @click="exportPdf()"
      title="Export (⌘E)"
    >
      <span x-text="exporting ? 'Exporting…' : 'Export PDF'"></span>
    </button>
  </div>

  <div
    x-show="showTemplates"
    x-cloak
    x-transition
    @click.outside="showTemplates = false"
    class="absolute left-1/2 top-14 z-40 w-[min(92vw,28rem)] -translate-x-1/2 rounded-xl border border-slate-line bg-slate-panel p-3 shadow-page"
  >
    <p class="mb-2 text-xs font-medium uppercase tracking-wider text-slate-muted">Start from template</p>
    <div class="grid gap-2 sm:grid-cols-2">
      <template x-for="tpl in templates" :key="tpl.id">
        <button
          type="button"
          class="rounded-lg border border-slate-line px-3 py-2.5 text-left transition hover:border-accent hover:bg-slate-hover"
          @click="applyTemplate(tpl.id)"
        >
          <span class="block text-sm font-medium text-fg" x-text="tpl.name"></span>
          <span class="mt-0.5 block text-xs text-slate-muted" x-text="tpl.description"></span>
        </button>
      </template>
    </div>
  </div>

  <div
    x-show="showSettings"
    x-cloak
    x-transition
    @click.outside="showSettings = false"
    class="absolute right-3 top-14 z-40 w-[min(92vw,20rem)] rounded-xl border border-slate-line bg-slate-panel p-4 shadow-page"
  >
    <p class="mb-3 text-xs font-medium uppercase tracking-wider text-slate-muted">Options</p>
    <div class="space-y-3 text-sm">
      <label class="flex items-center justify-between gap-3 text-fg">
        <span>Snap to grid</span>
        <input type="checkbox" class="accent-accent" x-model="snapEnabled" @change="saveSettings()" />
      </label>
      <label class="flex items-center justify-between gap-3 text-fg">
        <span>Show grid overlay</span>
        <input type="checkbox" class="accent-accent" x-model="showGrid" @change="saveSettings()" />
      </label>
      <label class="flex items-center justify-between gap-3 text-fg">
        <span>Margin guides</span>
        <input type="checkbox" class="accent-accent" x-model="showGuides" @change="saveSettings()" />
      </label>
      <div>
        <label class="panel-label">Page background</label>
        <div class="flex items-center gap-2">
          <input type="color" class="h-9 w-12 cursor-pointer rounded border border-slate-line bg-transparent" x-model="doc.pageBackground" @input="persistSoft()" @change="persist()" />
          <button type="button" class="btn-ghost" @click="doc.pageBackground = '#faf9f6'; persist()">Paper</button>
          <button type="button" class="btn-ghost" @click="doc.pageBackground = '#ffffff'; persist()">White</button>
        </div>
      </div>
      <div>
        <label class="panel-label">Theme</label>
        <div class="flex gap-2">
          <button type="button" class="btn-ghost flex-1" :class="theme === 'dark' && 'border-accent text-accent-soft'" @click="applyTheme('dark')">Dark</button>
          <button type="button" class="btn-ghost flex-1" :class="theme === 'light' && 'border-accent text-accent-soft'" @click="applyTheme('light')">Light</button>
        </div>
      </div>
    </div>
  </div>
</header>
