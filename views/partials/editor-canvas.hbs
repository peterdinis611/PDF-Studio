<section class="relative flex min-w-0 flex-1 flex-col bg-canvas">
  <div class="toolbar-strip flex shrink-0 flex-wrap items-center justify-center gap-1 border-b border-black/5 bg-slate-panel/95 px-2 py-2 backdrop-blur">
    <button type="button" class="tool-btn" :aria-pressed="tool === 'select'" @click="tool = 'select'; pendingLibraryKind = null; placeHint = false" title="Select (V)">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4l7 16 2.5-6.5L20 11 4 4z" />
      </svg>
    </button>
    <button type="button" class="tool-btn" :aria-pressed="tool === 'text'" @click="tool = 'text'" title="Text (T)">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 7V5h16v2M12 5v14m-4 0h8" />
      </svg>
    </button>
    <button type="button" class="tool-btn" :aria-pressed="tool === 'rect'" @click="tool = 'rect'" title="Rectangle (R)">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <rect x="5" y="6" width="14" height="12" rx="1" />
      </svg>
    </button>
    <button type="button" class="tool-btn" :aria-pressed="tool === 'ellipse'" @click="tool = 'ellipse'" title="Ellipse (O)">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <ellipse cx="12" cy="12" rx="8" ry="6" />
      </svg>
    </button>
    <button type="button" class="tool-btn" :aria-pressed="tool === 'line'" @click="tool = 'line'" title="Line (L)">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" d="M5 19L19 5" />
      </svg>
    </button>
    <button type="button" class="tool-btn" @click="$refs.imageInput.click()" title="Image (PNG/JPEG)">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.5-4.5a2 2 0 012.8 0L16 16m-2-2l1.5-1.5a2 2 0 012.8 0L20 14M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
    </button>

    <div class="mx-1 h-6 w-px bg-slate-line"></div>

    <button type="button" class="tool-btn" @click="duplicateSelected()" :disabled="!selected" title="Duplicate (⌘D)">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <rect x="8" y="8" width="11" height="11" rx="1" />
        <path stroke-linecap="round" d="M6 16V6a1 1 0 011-1h10" />
      </svg>
    </button>
    <button type="button" class="tool-btn" @click="toggleLock()" :disabled="!selected" title="Lock / unlock">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 11V8a4 4 0 118 0v3m-9 0h10v8H7v-8z" />
      </svg>
    </button>
    <button type="button" class="tool-btn text-warn/80 hover:text-warn" @click="deleteSelected()" :disabled="!selected" title="Delete">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 7h12M9 7V5h6v2m-8 0l1 12h8l1-12" />
      </svg>
    </button>

    <div class="mx-1 hidden h-6 w-px bg-slate-line sm:block"></div>

    <button type="button" class="tool-btn hidden sm:flex" @click="alignSelected('left')" :disabled="!selected" title="Align left">⇤</button>
    <button type="button" class="tool-btn hidden sm:flex" @click="alignSelected('center')" :disabled="!selected" title="Align center">↔</button>
    <button type="button" class="tool-btn hidden sm:flex" @click="alignSelected('right')" :disabled="!selected" title="Align right">⇥</button>
    <button type="button" class="tool-btn hidden md:flex" @click="alignSelected('middle')" :disabled="!selected" title="Align middle">↕</button>
  </div>

  <div
    x-show="placeHint"
    x-transition.opacity.duration.200ms
    class="place-banner pointer-events-none absolute left-1/2 top-16 z-20 -translate-x-1/2 rounded-full border border-accent/40 bg-slate-panel/95 px-4 py-1.5 text-xs text-accent-soft shadow-page backdrop-blur"
  >
    Click on the page to place the element · Esc to cancel
  </div>

  <div
    class="relative flex flex-1 items-start justify-center overflow-auto p-8 md:p-12"
    :class="tool === 'place' ? 'cursor-crosshair' : ''"
    @mousedown="onCanvasBackground($event)"
  >
    <div
      class="page-surface relative shrink-0 shadow-page transition-shadow duration-300"
      :class="tool === 'place' ? 'ring-2 ring-accent/50 ring-offset-4 ring-offset-canvas' : ''"
      :style="pageStyle"
      @mousedown="onPageMouseDown($event)"
      x-ref="page"
    >
      <div
        x-show="showGrid"
        class="guide-grid absolute inset-0 z-0"
        :style="`background-size: ${32 * zoom}px ${32 * zoom}px`"
      ></div>
      <div
        x-show="showGuides"
        class="pointer-events-none absolute inset-0 z-0 border border-dashed border-accent/40"
        :style="`margin: ${40 * zoom}px`"
      ></div>
      <template x-for="el in activePage.elements" :key="el.id">
        <div
          class="canvas-element"
          :class="{ 'is-selected': selectedId === el.id, 'is-pop': justInsertedId === el.id }"
          :data-el-id="el.id"
          :style="elementStyle(el)"
          @mousedown.stop="onElementMouseDown($event, el)"
          @dblclick.stop="(el.type === 'text' || el.type === 'sticky') && startTextEdit(el)"
        >
          <template x-if="el.type === 'text'">
            <div class="h-full w-full">
              <div
                x-show="editingTextId !== el.id"
                class="h-full w-full whitespace-pre-wrap break-words leading-snug"
                :style="textInnerStyle(el)"
                x-text="el.content"
              ></div>
              <div
                x-show="editingTextId === el.id"
                class="h-full w-full whitespace-pre-wrap break-words leading-snug outline-none"
                contenteditable="true"
                :style="textInnerStyle(el)"
                x-init="$watch('editingTextId', (id) => { if (id === el.id) { $el.innerText = el.content; $el.focus(); } })"
                @blur="finishTextEdit($event, el)"
                @keydown.escape.stop="$event.target.blur()"
              ></div>
            </div>
          </template>

          <template x-if="el.type === 'rect'">
            <div class="h-full w-full" :style="shapeStyle(el)"></div>
          </template>

          <template x-if="el.type === 'ellipse'">
            <div class="h-full w-full" :style="shapeStyle(el)"></div>
          </template>

          <template x-if="el.type === 'line'">
            <svg class="h-full w-full overflow-visible">
              <line x1="0" y1="0" :x2="el.width * zoom" :y2="el.height * zoom" :stroke="el.stroke" :stroke-width="el.strokeWidth * zoom" stroke-linecap="round" />
            </svg>
          </template>

          <template x-if="el.type === 'arrow'">
            <svg class="h-full w-full overflow-visible">
              <defs>
                <marker :id="'arrow-' + el.id" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L8,3 z" :fill="el.stroke" />
                </marker>
              </defs>
              <line
                x1="0"
                :y1="(el.height * zoom) / 2"
                :x2="el.width * zoom"
                :y2="(el.height * zoom) / 2"
                :stroke="el.stroke"
                :stroke-width="el.strokeWidth * zoom"
                stroke-linecap="round"
                :marker-end="'url(#arrow-' + el.id + ')'"
              />
            </svg>
          </template>

          <template x-if="el.type === 'divider'">
            <svg class="h-full w-full overflow-visible">
              <line
                x1="0"
                :y1="(el.height * zoom) / 2"
                :x2="el.width * zoom"
                :y2="(el.height * zoom) / 2"
                :stroke="el.stroke"
                :stroke-width="el.strokeWidth * zoom"
                :stroke-dasharray="el.style === 'dashed' ? `${6 * zoom} ${4 * zoom}` : 'none'"
              />
            </svg>
          </template>

          <template x-if="el.type === 'sticky'">
            <div
              class="flex h-full w-full flex-col p-2 shadow-sm"
              :style="`background:${el.fill}; color:${el.color}; font-size:${el.fontSize * zoom}px`"
            >
              <div
                x-show="editingTextId !== el.id"
                class="flex-1 whitespace-pre-wrap break-words"
                x-text="el.content"
              ></div>
              <div
                x-show="editingTextId === el.id"
                class="flex-1 whitespace-pre-wrap break-words outline-none"
                contenteditable="true"
                x-init="$watch('editingTextId', (id) => { if (id === el.id) { $el.innerText = el.content; $el.focus(); } })"
                @blur="finishTextEdit($event, el)"
              ></div>
            </div>
          </template>

          <template x-if="el.type === 'badge'">
            <div
              class="flex h-full w-full items-center justify-center font-semibold tracking-wide"
              :style="`background:${el.fill}; color:${el.color}; font-size:${el.fontSize * zoom}px; border-radius:${(el.height * zoom) / 2}px`"
              x-text="el.label"
            ></div>
          </template>

          <template x-if="el.type === 'checkbox'">
            <div class="flex h-full items-center gap-2" :style="`color:${el.color}; font-size:${el.fontSize * zoom}px`">
              <span
                class="flex shrink-0 items-center justify-center border-2"
                :style="`width:${16 * zoom}px; height:${16 * zoom}px; border-color:${el.color}`"
                x-text="el.checked ? '✓' : ''"
                @click.stop="el.checked = !el.checked; persist()"
              ></span>
              <span class="truncate" x-text="el.label"></span>
            </div>
          </template>

          <template x-if="el.type === 'icon'">
            <div class="flex h-full w-full items-center justify-center" x-html="iconHtml(el)"></div>
          </template>

          <template x-if="el.type === 'stamp'">
            <div class="relative flex h-full w-full items-center justify-center">
              <div
                class="absolute inset-1 rounded-full border-4"
                :style="`border-color:${el.color}`"
              ></div>
              <div
                class="absolute inset-3 rounded-full border"
                :style="`border-color:${el.color}`"
              ></div>
              <span
                class="relative z-10 font-bold tracking-widest"
                :style="`color:${el.color}; font-size:${el.fontSize * zoom}px`"
                x-text="el.label"
              ></span>
            </div>
          </template>

          <template x-if="el.type === 'table'">
            <div class="grid h-full w-full overflow-hidden" :style="`grid-template-columns: repeat(${el.cols}, 1fr); grid-template-rows: repeat(${el.rows}, 1fr); border:1px solid ${el.stroke}`">
              <template x-for="(cell, i) in el.cells" :key="i">
                <div
                  class="flex items-center overflow-hidden px-1"
                  :style="`border:0.5px solid ${el.stroke}; background:${el.header && i < el.cols ? el.headerFill : el.fill}; color:${el.header && i < el.cols ? '#fff' : el.color}; font-size:${el.fontSize * zoom}px; font-weight:${el.header && i < el.cols ? '600' : '400'}`"
                  x-text="cell"
                ></div>
              </template>
            </div>
          </template>

          <template x-if="el.type === 'image'">
            <img class="h-full w-full object-contain" :src="el.src" :alt="el.name" draggable="false" />
          </template>

          <template x-if="selectedId === el.id && !el.locked">
            <div>
              <span class="resize-handle -bottom-1 -right-1 cursor-se-resize" @mousedown.stop="startResize($event, el)"></span>
            </div>
          </template>
        </div>
      </template>
    </div>
  </div>
</section>
