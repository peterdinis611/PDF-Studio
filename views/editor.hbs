<div
  x-data="pdfEditor"
  @keydown.window="onKeydown($event)"
  class="editor-shell flex h-full flex-col"
>
  {{> editor-toolbar}}

  <div class="flex min-h-0 flex-1">
    {{> editor-rail}}

    {{> editor-canvas}}

    {{> editor-inspector}}
  </div>

  <footer class="status-bar">
    <div class="flex min-w-0 items-center gap-2.5">
      <span class="status-chip" x-text="'Page ' + (activePageIndex + 1) + ' / ' + doc.pages.length"></span>
      <span class="status-chip" x-show="selectedIds.length" x-text="selectedIds.length + ' selected'"></span>
      <span class="status-chip accent" x-show="editingMaster">Master</span>
      <span class="status-chip accent" x-show="reviewMode">Review</span>
    </div>
    <p class="hidden text-[11px] text-slate-muted md:block">
      <span class="opacity-70">Space</span> pan
      <span class="mx-2 opacity-30">·</span>
      <span class="opacity-70">⌘ scroll</span> zoom
      <span class="mx-2 opacity-30">·</span>
      <span class="opacity-70">/</span> search
    </p>
    <div class="flex items-center gap-1.5">
      <button type="button" class="status-action" @click="fitWidth()">Fit width</button>
      <button type="button" class="status-action" @click="fitPage()">Fit page</button>
      <span class="ml-1 font-mono text-[11px] tabular-nums text-slate-muted" x-text="Math.round(zoom * 100) + '%'"></span>
    </div>
  </footer>

  <input type="file" accept="image/png,image/jpeg" class="hidden" x-ref="imageInput" @change="onImageSelected($event)" />
  <input type="file" accept="image/png,image/jpeg" class="hidden" x-ref="signatureFileInput" @change="onSignatureFileSelected($event)" />
  <input type="file" accept="application/pdf,.pdf" class="hidden" x-ref="pdfInput" @change="onPdfImportSelected($event)" />
  <input type="file" accept="application/json,.json,.pdfstudio.json" class="hidden" x-ref="jsonInput" @change="onStudioJsonSelected($event)" />
  <input type="file" accept="image/png,image/jpeg" class="hidden" x-ref="brandLogoInput" @change="onBrandLogoSelected($event)" />

  {{> editor-modals}}
</div>
