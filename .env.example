# Runtime (optional — defaults work for Docker / most PaaS)
PORT=3847
HOST=0.0.0.0
NODE_ENV=production

# Logging
LOG_LEVEL=info
# Max in-memory audit events (ring buffer)
AUDIT_LOG_CAPACITY=500
# If set, /audit-logs and GET /api/audit-logs require this token
# (header X-Audit-Token, Authorization: Bearer, or ?token=).
# If unset: open in development, hidden (404) in production.
# AUDIT_LOGS_TOKEN=
